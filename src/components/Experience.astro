---
import { content } from '../data/content';
import { Briefcase, Zap, Bot, Database, Code, Activity } from 'lucide-react';

const { oci, earlier } = content.experience;
---

<section id="experience" class="py-24 bg-muted/30 scroll-mt-20">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-12">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
        <Briefcase class="w-5 h-5 text-primary" />
      </div>
      <h2 class="font-display text-3xl font-bold uppercase tracking-tight">Work Experience</h2>
    </div>

    <!-- Summary Highlight -->
    <div class="mb-16 p-8 rounded-3xl bg-card border border-border/50 text-center max-w-4xl mx-auto">
      <p class="text-xl md:text-2xl text-muted-foreground leading-relaxed mb-8">
        {content.summary.p2} <span class="text-foreground font-bold">{content.summary.p2Highlight}</span>{content.summary.p2End}
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
        {content.competencies.map((item) => (
          <div class="p-6 rounded-2xl bg-background border border-border group hover:border-primary/30 transition-all text-left flex flex-col">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                <Zap class="w-4 h-4 text-primary" />
              </div>
              <span class="text-sm font-bold group-hover:text-primary transition-colors leading-tight">{item.title}</span>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed flex-1">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- OCI Main Role -->
    <div class="mb-12">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
        <div>
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center p-2 border border-border/50">
              <img src="/logos/Oracle_logo.svg" alt="Oracle" class="w-full h-auto" />
            </div>
            <div>
              <h3 class="font-display text-3xl font-bold">{oci.company}</h3>
              <p class="text-muted-foreground uppercase tracking-widest text-xs font-bold">{oci.location}</p>
            </div>
          </div>
          <p class="text-primary font-bold text-lg mb-1">{oci.role}</p>
          <p class="text-sm text-muted-foreground font-medium">{oci.period}</p>
        </div>
      </div>

      <ul class="grid md:grid-cols-2 gap-4 text-muted-foreground mb-12">
        {oci.highlights.map((h) => (
          <li class="flex items-start gap-3 bg-card p-4 rounded-2xl border border-border/50">
            <span class="text-primary font-bold mt-1">/</span>
            <span class="text-sm leading-relaxed">{h}</span>
          </li>
        ))}
      </ul>

      <!-- Bento Grid for Achievements -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-12">
        <!-- CI/CD Featured Achievement -->
        <div class="md:col-span-4 p-8 rounded-3xl bg-gradient-to-br from-primary/10 via-background to-background border border-primary/20 hover:border-primary/40 transition-all group relative overflow-hidden">
          <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
            <Activity class="w-32 h-32" />
          </div>
          <div class="relative z-10 flex flex-col lg:flex-row lg:items-center justify-between gap-8">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-12 h-12 rounded-2xl bg-primary/20 flex items-center justify-center">
                  <Activity class="w-6 h-6 text-primary" />
                </div>
                <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest">
                  {oci.featuredAchievement.badge}
                </span>
              </div>
              <h4 class="font-display text-3xl font-bold mb-4">{oci.featuredAchievement.title}</h4>
              <p class="text-muted-foreground leading-relaxed mb-6 max-w-2xl">{oci.featuredAchievement.desc}</p>
              <ul class="grid sm:grid-cols-2 gap-3">
                {oci.featuredAchievement.points.map((p) => (
                  <li class="flex items-center gap-2 text-sm text-muted-foreground">
                    <div class="w-1.5 h-1.5 rounded-full bg-primary" />
                    {p}
                  </li>
                ))}
              </ul>
            </div>
            <div class="flex flex-row lg:flex-col gap-3">
              {oci.featuredAchievement.metrics.map((m) => (
                <div class="flex-1 lg:w-32 p-4 rounded-2xl bg-primary/5 border border-primary/10 text-center">
                  <div class="text-2xl font-display font-bold text-primary">{m.value}</div>
                  <div class="text-xs text-muted-foreground uppercase font-bold tracking-tight leading-none mt-1">{m.label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Other Bento Cards -->
        {oci.bentoCards.map((card, i) => {
          const isHighValue = card.title === "Performance Hub AI" || card.title === "OCI Database Management";
          const bgColor = i === 0 ? "bg-gradient-to-br from-primary/10 to-background border-primary/20" : 
                          i === 1 ? "bg-gradient-to-br from-accent/10 to-background border-accent/20" : 
                          "bg-card border-border/50";
          const iconColor = i === 0 ? "text-primary" : i === 1 ? "text-accent" : "text-muted-foreground";
          const iconBg = i === 0 ? "bg-primary/10" : i === 1 ? "bg-accent/10" : "bg-muted/10";

          return (
            <div class={`p-8 rounded-3xl border hover:border-primary/30 transition-all flex flex-col min-h-[260px] ${i < 2 ? 'md:col-span-2' : 'md:col-span-1'} ${bgColor}`}>
              <div class="flex items-center justify-between mb-6">
                 <div class={`w-12 h-12 rounded-2xl ${iconBg} flex items-center justify-center`}>
                   {i === 0 ? <Bot class={`w-7 h-7 ${iconColor}`} /> : 
                    i === 1 ? <Database class={`w-7 h-7 ${iconColor}`} /> : 
                    <Code class={`w-6 h-6 ${iconColor}`} />}
                 </div>
                 {card.badge && (
                   <span class={`px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest ${i === 0 ? 'bg-primary/10 text-primary' : i === 1 ? 'bg-accent/10 text-accent' : 'bg-muted text-muted-foreground'}`}>
                     {card.badge}
                   </span>
                 )}
              </div>
              <h4 class="font-display text-2xl font-bold mb-3">{card.title}</h4>
              <p class="text-sm text-muted-foreground leading-relaxed flex-1">{card.desc}</p>
              {card.metric && (
                 <span class="text-xs font-bold text-primary uppercase tracking-widest mt-6 pt-4 border-t border-border/30 inline-block">{card.metric}</span>
              )}
            </div>
          );
        })}
      </div>
    </div>

    <!-- Earlier Experience -->
    <div class="grid md:grid-cols-2 gap-6 mt-16">
      {earlier.map((role) => (
        <div class="p-8 rounded-3xl bg-card border border-border/50 hover:border-primary/20 transition-all flex flex-col">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center p-1.5 border border-border/50 shrink-0">
              <img 
                src={role.company.includes('Oracle') ? '/logos/Oracle_logo.svg' : '/logos/IBM_logo.svg'} 
                alt={role.company} 
                class="w-full h-auto" 
              />
            </div>
            <h3 class="font-display text-2xl font-bold">{role.company}</h3>
          </div>
          <p class="text-primary font-bold text-sm mb-4">{role.role} · {role.period}</p>
          <p class="text-sm text-muted-foreground leading-relaxed mb-6 flex-1">{role.desc}</p>
          <div class="p-4 rounded-2xl bg-muted/30 border border-border/50">
            <p class="text-xs text-muted-foreground italic leading-relaxed">"{role.recommendation}"</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
