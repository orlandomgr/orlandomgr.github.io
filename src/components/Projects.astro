---
import { content } from '../data/content';
import { FolderGit2, Github, Sparkles, Bot, Search, Database, Activity, Code } from 'lucide-react';

const getProjectIcon = (title: string) => {
  const t = title.toLowerCase();
  if (t.includes('ai') || t.includes('agent')) return Bot;
  if (t.includes('search')) return Search;
  if (t.includes('database')) return Database;
  if (t.includes('monitoring') || t.includes('performance')) return Activity;
  return Code;
};
---

<section id="projects" class="py-24 bg-muted/30 scroll-mt-20">
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center justify-between mb-12">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
          <FolderGit2 class="w-5 h-5 text-primary" />
        </div>
        <h2 class="font-display text-3xl font-bold uppercase tracking-tight">Featured Projects</h2>
      </div>
      <a 
        href={`https://github.com/${content.github}`} 
        target="_blank" 
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors font-bold uppercase tracking-widest"
      >
        <Github class="w-4 h-4" />
        {content.github}
      </a>
    </div>

    <div class="space-y-8">
      {content.projects.map((project) => {
        const Icon = getProjectIcon(project.title);
        return (
          <div class="p-8 md:p-12 rounded-[3rem] bg-gradient-to-br from-primary/10 via-background to-background border border-primary/20 hover:border-primary/40 transition-all group relative overflow-hidden">
            <div class="absolute top-0 right-0 p-12 opacity-5 group-hover:opacity-10 transition-opacity">
              <Icon class="w-48 h-48" />
            </div>
            
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-8">
                <div class="w-14 h-14 rounded-2xl bg-primary/20 flex items-center justify-center group-hover:bg-primary/30 transition-colors">
                  <Icon class="w-7 h-7 text-primary" />
                </div>
                <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest border border-primary/10">
                  {project.badge}
                </span>
              </div>

              <h3 class="font-display text-3xl font-bold mb-4 group-hover:text-primary transition-colors">{project.title}</h3>
              
              <p class="text-base text-muted-foreground leading-relaxed mb-8 max-w-3xl">
                {project.desc}
              </p>

              {project.points && (
                <ul class="grid sm:grid-cols-2 gap-4 mb-8">
                  {project.points.map((p) => (
                    <li class="flex items-start gap-3 text-sm text-muted-foreground">
                      <div class="w-1.5 h-1.5 rounded-full bg-primary mt-2 shrink-0" />
                      <span>{p}</span>
                    </li>
                  ))}
                </ul>
              )}

              <div class="flex flex-wrap gap-2">
                {project.tech.map((t) => (
                  <span class="px-2.5 py-1 rounded-lg text-xs font-bold bg-primary/5 text-primary uppercase tracking-tight border border-primary/10">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Featured Skills Highlight -->
    <div class="mt-12 p-8 md:p-12 rounded-[3.5rem] bg-gradient-to-br from-primary/10 via-background to-background border border-primary/20 hover:border-primary/40 transition-all group relative overflow-hidden">
      <div class="absolute top-0 right-0 p-12 opacity-5 group-hover:opacity-10 transition-opacity">
        <Sparkles class="w-48 h-48" />
      </div>

      <div class="relative z-10">
        <div class="flex items-center justify-between mb-8">
          <div class="w-14 h-14 rounded-2xl bg-primary/20 flex items-center justify-center group-hover:bg-primary/30 transition-colors">
            <Sparkles class="w-7 h-7 text-primary" />
          </div>
          <span class="px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest border border-primary/10">
            Agentic Workflows
          </span>
        </div>

        <h3 class="font-display text-3xl font-bold mb-4 group-hover:text-primary transition-colors">AI Engineering Leadership</h3>
        
        <p class="text-base text-muted-foreground leading-relaxed mb-8 max-w-3xl">
          Expert in architecting autonomous systems using multi-agent orchestration and LLMs to drive operational efficiency and technical innovation.
        </p>

        <div class="flex flex-wrap gap-2">
          {["Multi-Agent Orchestration", "LLM Integration", "Enterprise AI Architecture", "Autonomous Systems"].map((t) => (
            <span class="px-2.5 py-1 rounded-lg text-xs font-bold bg-primary/5 text-primary uppercase tracking-tight border border-primary/10">
              {t}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
